      "source": [
        "\"\"\"\n",
        "================================================================================\n",
        "Extract unique O/D coordinates from the corrected trip-level dataset\n",
        "\n",
        "================================================================================\n",
        "\"\"\"\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import geopandas as gpd\n",
        "from shapely.geometry import Point\n",
        "\n",
        "print(\"=\" * 70)\n",
        "print(\"  EXTRACT UNIQUE O/D COORDINATES FOR REMOTE SENSING\")\n",
        "print(\"=\" * 70)\n",
        "\n",
        "# ============================================================================\n",
        "# STEP 1: Load corrected trip-level dataset\n",
        "# ============================================================================\n",
        "\n",
        "df = pd.read_csv('./chicago_trip_level_logistic_dataset.csv')\n",
        "print(f\"\\nLoaded: {len(df):,} trips, {len(df.columns)} columns\")\n",
        "\n",
        "# Verify coordinates are not NaN\n",
        "print(f\"\\n  orig_lat NaN: {df['orig_lat'].isna().sum():,}\")\n",
        "print(f\"  orig_lon NaN: {df['orig_lon'].isna().sum():,}\")\n",
        "print(f\"  dest_lat NaN: {df['dest_lat'].isna().sum():,}\")\n",
        "print(f\"  dest_lon NaN: {df['dest_lon'].isna().sum():,}\")\n",
        "\n",
        "# Quick sanity check: longitude should be negative for Chicago\n",
        "print(f\"\\n  orig_lon range: {df['orig_lon'].min():.4f} to {df['orig_lon'].max():.4f}\")\n",
        "print(f\"  dest_lon range: {df['dest_lon'].min():.4f} to {df['dest_lon'].max():.4f}\")\n",
        "\n",
        "# ============================================================================\n",
        "# STEP 2: Extract unique coordinates\n",
        "# ============================================================================\n",
        "\n",
        "print(\"\\n[STEP 2] Extracting unique coordinates...\")\n",
        "\n",
        "# Drop trips with missing coordinates\n",
        "df_valid = df.dropna(subset=['orig_lat', 'orig_lon', 'dest_lat', 'dest_lon']).copy()\n",
        "print(f\"  Trips with valid coords: {len(df_valid):,}\")\n",
        "\n",
        "# --- Origins ---\n",
        "origins = df_valid[['orig_lat', 'orig_lon']].copy()\n",
        "origins.columns = ['lat', 'lon']\n",
        "origins['role'] = 'origin'\n",
        "\n",
        "# --- Destinations ---\n",
        "destinations = df_valid[['dest_lat', 'dest_lon']].copy()\n",
        "destinations.columns = ['lat', 'lon']\n",
        "destinations['role'] = 'destination'\n",
        "\n",
        "# --- Combine and deduplicate ---\n",
        "# Round to 6 decimals (≈ 0.11m precision)\n",
        "all_coords = pd.concat([origins, destinations], ignore_index=True)\n",
        "all_coords['lat_round'] = all_coords['lat'].round(6)\n",
        "all_coords['lon_round'] = all_coords['lon'].round(6)\n",
        "\n",
        "unique_coords = (\n",
        "    all_coords\n",
        "    .drop_duplicates(subset=['lat_round', 'lon_round'], keep='first')\n",
        "    [['lat_round', 'lon_round']]\n",
        "    .copy()\n",
        "    .reset_index(drop=True)\n",
        ")\n",
        "unique_coords.columns = ['lat', 'lon']\n",
        "unique_coords['point_id'] = range(1, len(unique_coords) + 1)\n",
        "\n",
        "# --- Count usage as origin vs destination ---\n",
        "orig_counts = (\n",
        "    all_coords[all_coords['role'] == 'origin']\n",
        "    .groupby(['lat_round', 'lon_round']).size()\n",
        "    .reset_index(name='n_as_origin')\n",
        ")\n",
        "orig_counts.columns = ['lat', 'lon', 'n_as_origin']\n",
        "\n",
        "dest_counts = (\n",
        "    all_coords[all_coords['role'] == 'destination']\n",
        "    .groupby(['lat_round', 'lon_round']).size()\n",
        "    .reset_index(name='n_as_dest')\n",
        ")\n",
        "dest_counts.columns = ['lat', 'lon', 'n_as_dest']\n",
        "\n",
        "unique_detailed = unique_coords.merge(orig_counts, on=['lat', 'lon'], how='left')\n",
        "unique_detailed = unique_detailed.merge(dest_counts, on=['lat', 'lon'], how='left')\n",
        "unique_detailed['n_as_origin'] = unique_detailed['n_as_origin'].fillna(0).astype(int)\n",
        "unique_detailed['n_as_dest'] = unique_detailed['n_as_dest'].fillna(0).astype(int)\n",
        "unique_detailed['n_total'] = unique_detailed['n_as_origin'] + unique_detailed['n_as_dest']\n",
        "\n",
        "print(f\"\\n  Total origin trip-points:      {len(origins):,}\")\n",
        "print(f\"  Total destination trip-points: {len(destinations):,}\")\n",
        "print(f\"  Unique locations:              {len(unique_coords):,}\")\n",
        "\n",
        "# --- Also separate unique origins and destinations ---\n",
        "unique_origins = origins.drop_duplicates(subset=['lat', 'lon'])[['lat', 'lon']].reset_index(drop=True)\n",
        "unique_dests = destinations.drop_duplicates(subset=['lat', 'lon'])[['lat', 'lon']].reset_index(drop=True)\n",
        "\n",
        "print(f\"  Unique origin locations:       {len(unique_origins):,}\")\n",
        "print(f\"  Unique destination locations:  {len(unique_dests):,}\")\n",
        "\n",
        "# ============================================================================\n",
        "# STEP 3: Save outputs\n",
        "# ============================================================================\n",
        "\n",
        "print(\"\\n[STEP 3] Saving...\")\n",
        "\n",
        "# File 1: Simple unique coordinates\n",
        "unique_coords[['point_id', 'lat', 'lon']].to_csv(\n",
        "    './od_unique_coordinates.csv', index=False\n",
        ")\n",
        "print(f\"  Saved: ./od_unique_coordinates.csv ({len(unique_coords):,} points)\")\n",
        "\n",
        "# File 2: Detailed with counts\n",
        "unique_detailed.to_csv('./od_unique_coordinates_detailed.csv', index=False)\n",
        "print(f\"  Saved: ./od_unique_coordinates_detailed.csv\")\n",
        "\n",
        "# File 3: Origins only\n",
        "unique_origins.to_csv('./od_unique_origins.csv', index=False)\n",
        "print(f\"  Saved: ./od_unique_origins.csv ({len(unique_origins):,} points)\")\n",
        "\n",
        "# File 4: Destinations only\n",
        "unique_dests.to_csv('./od_unique_destinations.csv', index=False)\n",
        "print(f\"  Saved: ./od_unique_destinations.csv ({len(unique_dests):,} points)\")\n",
        "\n",
        "# File 5: GeoJSON for visualization\n",
        "try:\n",
        "    geo_df = gpd.GeoDataFrame(\n",
        "        unique_detailed,\n",
        "        geometry=[Point(lon, lat) for lon, lat in\n",
        "                  zip(unique_detailed['lon'], unique_detailed['lat'])],\n",
        "        crs='EPSG:4326'\n",
        "    )\n",
        "    geo_df.to_file('./od_unique_coordinates.geojson', driver='GeoJSON')\n",
        "    print(f\"  Saved: ./od_unique_coordinates.geojson\")\n",
        "except Exception as e:\n",
        "    print(f\"  GeoJSON failed: {e}\")\n",
        "\n",
        "# ============================================================================\n",
        "# Summary\n",
        "# ============================================================================\n",
        "\n",
        "print(f\"\"\"\n",
        "{'='*70}\n",
        "  SUMMARY\n",
        "{'='*70}\n",
        "  Unique locations for imagery download: {len(unique_coords):,}\n",
        "\n",
        "  Geographic extent:\n",
        "    North: {unique_coords['lat'].max():.6f}\n",
        "    South: {unique_coords['lat'].min():.6f}\n",
        "    East:  {unique_coords['lon'].max():.6f}\n",
        "    West:  {unique_coords['lon'].min():.6f}\n",
        "\n",
        "  Top 10 most-used locations:\n",
        "\"\"\")\n",
        "print(unique_detailed.nlargest(10, 'n_total')[\n",
        "    ['point_id', 'lat', 'lon', 'n_as_origin', 'n_as_dest', 'n_total']\n",
