        "\n",
        "# ############################################################################\n",
        "#\n",
        "#   MAIN PIPELINE\n",
        "#\n",
        "# ############################################################################\n",
        "\n",
        "def run_trip_level_pipeline():\n",
        "    \"\"\"Execute the complete trip-level logistic regression pipeline.\"\"\"\n",
        "\n",
        "    print_section(\"CHICAGO TRIP-LEVEL DISCRETE CHOICE MODEL\")\n",
        "    print(f\"  Timestamp: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n",
        "\n",
        "    # === STEP 1: Load data ===\n",
        "    print_step(1, \"Loading Data\")\n",
        "    place_df     = load_csv(Config.PLACE_DF,     \"Place/Trip Data\")\n",
        "    person_df    = load_csv(Config.PERSON_DF,     \"Person Data\")\n",
        "    household_df = load_csv(Config.HOUSEHOLD_DF,  \"Household Data\")\n",
        "    location_df  = load_csv(Config.LOCATION_DF,   \"Location Data\")\n",
        "\n",
        "    # === STEP 2: Filter to Chicago ===\n",
        "    print_step(2, \"Filtering to Chicago\")\n",
        "    valid_sampnos = None\n",
        "    if os.path.exists(Config.CHICAGO_BOUNDARY_SHP):\n",
        "        chi_gdf = gpd.read_file(Config.CHICAGO_BOUNDARY_SHP)\n",
        "        if chi_gdf.crs is None:\n",
        "            chi_gdf = chi_gdf.set_crs(Config.CRS_WGS84)\n",
        "        chi_gdf = chi_gdf.to_crs(Config.CRS_ILLINOIS)\n",
        "        chicago_boundary = chi_gdf.geometry.unary_union\n",
        "\n",
        "        loc = location_df.copy()\n",
        "        homes = loc[loc['home'] == 1].copy()\n",
        "        homes['latitude']  = pd.to_numeric(homes['latitude'], errors='coerce')\n",
        "        homes['longitude'] = pd.to_numeric(homes['longitude'], errors='coerce')\n",
        "        homes = homes.dropna(subset=['latitude', 'longitude'])\n",
        "        homes = homes[\n",
        "            (homes['latitude'] >= Config.LAT_MIN) & (homes['latitude'] <= Config.LAT_MAX) &\n",
        "            (homes['longitude'] >= Config.LON_MIN) & (homes['longitude'] <= Config.LON_MAX)\n",
        "        ]\n",
        "        homes = homes.drop_duplicates(subset='sampno', keep='first')\n",
        "\n",
        "        geom = [Point(lon, lat) for lon, lat in zip(homes['longitude'], homes['latitude'])]\n",
        "        homes_gdf = gpd.GeoDataFrame(homes, geometry=geom, crs=Config.CRS_WGS84)\n",
        "        homes_gdf = homes_gdf.to_crs(Config.CRS_ILLINOIS)\n",
        "        homes_gdf['in_chicago'] = homes_gdf.geometry.apply(lambda p: chicago_boundary.contains(p))\n",
        "        valid_sampnos = set(homes_gdf.loc[homes_gdf['in_chicago'], 'sampno'].unique())\n",
        "        print(f\"  Chicago households: {len(valid_sampnos):,}\")\n",
        "\n",
        "    # === STEP 3: Build trip records ===\n",
        "    print_step(3, \"Building Trip-Level Records with O/D Info\")\n",
        "    trips = build_trip_records(place_df, location_df,\n",
        "                                valid_sampnos=valid_sampnos,\n",
        "                                home_based_only=True)\n",
        "\n",
        "    # === STEP 4: Assign to zones ===\n",
        "    print_step(4, \"Assigning O/D to Census Block Groups\")\n",
        "    trips = assign_od_to_zones(trips, Config.CBG_SHP)\n",
        "\n",
        "    # === STEP 5: Zone features ===\n",
        "    print_step(5, \"Computing Zone Features & Attaching to Trips\")\n",
        "    all_geoids = set(trips['orig_GEOID'].unique()) | set(trips['dest_GEOID'].unique())\n",
        "    zone_features = compute_zone_features(\n",
        "        Config.CBG_SHP, Config.EPA_CSV, Config.BE_DF,\n",
        "        Config.CBD_SHP, Config.PARK_SHP, all_geoids\n",
        "    )\n",
        "    trips = attach_zone_features_to_trips(trips, zone_features)\n",
        "\n",
        "    # === STEP 6: Person/HH features ===\n",
        "    print_step(6, \"Attaching Person/Household Features\")\n",
        "    trips = attach_person_household_features(\n",
        "        trips, person_df, household_df, valid_sampnos\n",
        "    )\n",
        "\n",
        "    # === STEP 7: Clean and save ===\n",
        "    print_step(7, \"Cleaning and Saving Dataset\")\n",
        "    exclude_from_cleaning = [\n",
        "        'sampno', 'perno',\n",
        "        'orig_lat', 'orig_lon', 'dest_lat', 'dest_lon',  # coordinates are negative in Western Hemisphere\n",
        "        'home_x', 'home_y',   # projected coordinates can be any sign\n",
        "        'o_cx', 'o_cy', 'd_cx', 'd_cy'  # centroids\n",
        "    ]\n",
        "    # Replace negative survey codes with NaN\n",
        "    numeric_cols = trips.select_dtypes(include=[np.number]).columns\n",
        "    for col in numeric_cols:\n",
        "        if col not in exclude_from_cleaning:\n",
        "            n_neg = (trips[col] < 0).sum()\n",
        "            if n_neg > 0:\n",
        "                trips.loc[trips[col] < 0, col] = np.nan\n",
        "                print(f\"    {col}: {n_neg:,} negatives -> NaN\")\n",
        "\n",
        "    trips.to_csv(Config.OUTPUT_TRIP_DATASET, index=False)\n",
        "    print(f\"\\n  Saved: {Config.OUTPUT_TRIP_DATASET}\")\n",
        "    print(f\"  Rows: {len(trips):,}\")\n",
        "    print(f\"  Columns: {len(trips.columns)}\")\n",
        "\n",
        "    # === STEP 8: Fit logistic models ===\n",
        "    print_step(8, \"Fitting Logistic Regression Models\")\n",
        "    results = fit_logistic_models(trips)\n",
        "\n",
        "    # === SUMMARY ===\n",
        "    print_section(\"PIPELINE COMPLETE\")\n",
        "    print(f\"  Trip records: {len(trips):,}\")\n",
        "    print(f\"  Transit rate: {trips['is_transit'].mean()*100:.1f}%\")\n",
        "    print(f\"  Active rate:  {trips['is_active'].mean()*100:.1f}%\")\n",
        "\n",
        "    return trips, results\n",
        "\n",
        "\n",
        "# ============================================================================\n",
        "# RUN\n",
        "# ============================================================================\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    try:\n",
        "        trips_data, model_results = run_trip_level_pipeline()\n",
        "    except Exception as e:\n",
        "        print(f\"\\nERROR: {e}\")\n",
        "        import traceback\n",
        "        traceback.print_exc()"
      ],
