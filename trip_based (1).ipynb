      "cell_type": "code",
      "source": [
        "\n",
        "# ############################################################################\n",
        "#\n",
        "#   PHASE 3: BUILD TRIP-LEVEL RECORDS WITH O/D COORDINATES\n",
        "#\n",
        "#\n",
        "# ############################################################################\n",
        "\n",
        "def build_trip_records(place_df, location_df, valid_sampnos=None,\n",
        "                       home_based_only=True):\n",
        "    \"\"\"\n",
        "    Build trip-level records with origin and destination coordinates.\n",
        "\n",
        "    Each row = one trip segment with:\n",
        "      - Origin location (coordinates of where the trip started)\n",
        "      - Destination location (coordinates of where the trip ended)\n",
        "      - Travel mode, time, distance\n",
        "\n",
        "    Key logic for determining origin:\n",
        "      - The ORIGIN of trip N = the DESTINATION of trip (N-1)\n",
        "      - The origin of the FIRST trip of the day = home (locno 10000)\n",
        "\n",
        "    Parameters\n",
        "    ----------\n",
        "    place_df : DataFrame\n",
        "        Raw place/trip file\n",
        "    location_df : DataFrame\n",
        "        Location file with coordinates\n",
        "    valid_sampnos : set or None\n",
        "        Chicago-only household IDs\n",
        "    home_based_only : bool\n",
        "        If True, keep only trips starting from or ending at home\n",
        "\n",
        "    Returns\n",
        "    -------\n",
        "    DataFrame with one row per trip, including O/D coordinates\n",
        "    \"\"\"\n",
        "\n",
        "    print(\"  Building trip-level records...\")\n",
        "\n",
        "    trips = place_df.copy()\n",
        "\n",
        "    # Filter to Chicago residents\n",
        "    if valid_sampnos is not None:\n",
        "        trips = trips[trips['sampno'].isin(valid_sampnos)].copy()\n",
        "        print(f\"    Filtered to Chicago: {len(trips):,} trips\")\n",
        "\n",
        "    # Clean key columns\n",
        "    trips['locno']    = pd.to_numeric(trips['locno'], errors='coerce')\n",
        "    trips['travtime'] = pd.to_numeric(trips['travtime'], errors='coerce').fillna(0).clip(lower=0)\n",
        "    trips['distance'] = pd.to_numeric(trips.get('distance', pd.Series(dtype=float)),\n",
        "                                       errors='coerce').fillna(0)\n",
        "\n",
        "    # Sort by person and trip sequence\n",
        "    sort_col = 'placeno' if 'placeno' in trips.columns else 'plession'\n",
        "    trips = trips.sort_values(['sampno', 'perno', sort_col]).reset_index(drop=True)\n",
        "\n",
        "    # -----------------------------------------------------------------\n",
        "    # Determine origin and destination locno for each trip\n",
        "    #\n",
        "    #\n",
        "    # -----------------------------------------------------------------\n",
        "    trips['dest_locno'] = trips['locno'].astype(int)\n",
        "    trips['orig_locno'] = (\n",
        "        trips.groupby(['sampno', 'perno'])['locno']\n",
        "        .shift(1)\n",
        "        .fillna(Config.HOME_LOCNO)\n",
        "        .astype(int)\n",
        "    )\n",
        "\n",
        "    # Trip sequence number within each person's day\n",
        "    trips['trip_seq'] = trips.groupby(['sampno', 'perno']).cumcount() + 1\n",
        "\n",
        "    # Identify home-based trips\n",
        "    trips['is_home_orig'] = (trips['orig_locno'] == Config.HOME_LOCNO)\n",
        "    trips['is_home_dest'] = (trips['dest_locno'] == Config.HOME_LOCNO)\n",
        "    trips['is_home_based'] = trips['is_home_orig'] | trips['is_home_dest']\n",
        "\n",
        "    total = len(trips)\n",
        "    hb = trips['is_home_based'].sum()\n",
        "    print(f\"    Total trips: {total:,}\")\n",
        "    print(f\"    Home-based: {hb:,} ({hb/total*100:.1f}%)\")\n",
        "\n",
        "    if home_based_only:\n",
        "        trips = trips[trips['is_home_based']].copy()\n",
        "        print(f\"    After HB filter: {len(trips):,}\")\n",
        "\n",
        "    # -----------------------------------------------------------------\n",
        "    # Look up coordinates for origin and destination from location file\n",
        "    #\n",
        "    # 从 location file\n",
        "    # -----------------------------------------------------------------\n",
        "    loc = location_df.copy()\n",
        "    loc['latitude']  = pd.to_numeric(loc['latitude'], errors='coerce')\n",
        "    loc['longitude'] = pd.to_numeric(loc['longitude'], errors='coerce')\n",
        "    loc = loc.dropna(subset=['latitude', 'longitude'])\n",
        "    loc = loc[\n",
        "        (loc['latitude']  >= Config.LAT_MIN) & (loc['latitude']  <= Config.LAT_MAX) &\n",
        "        (loc['longitude'] >= Config.LON_MIN) & (loc['longitude'] <= Config.LON_MAX)\n",
        "    ]\n",
        "    loc['sampno'] = pd.to_numeric(loc['sampno'], errors='coerce').astype('Int64')\n",
        "    loc['locno']  = pd.to_numeric(loc['locno'], errors='coerce').astype('Int64')\n",
        "\n",
        "    loc_lookup = (\n",
        "        loc.drop_duplicates(subset=['sampno', 'locno'], keep='first')\n",
        "        [['sampno', 'locno', 'latitude', 'longitude']]\n",
        "    )\n",
        "\n",
        "    # Merge ORIGIN coordinates\n",
        "    trips = trips.merge(\n",
        "        loc_lookup.rename(columns={\n",
        "            'locno': 'orig_locno', 'latitude': 'orig_lat', 'longitude': 'orig_lon'\n",
        "        }),\n",
        "        on=['sampno', 'orig_locno'], how='left'\n",
        "    )\n",
        "\n",
        "    # Merge DESTINATION coordinates\n",
        "    trips = trips.merge(\n",
        "        loc_lookup.rename(columns={\n",
        "            'locno': 'dest_locno', 'latitude': 'dest_lat', 'longitude': 'dest_lon'\n",
        "        }),\n",
        "        on=['sampno', 'dest_locno'], how='left'\n",
        "    )\n",
        "\n",
        "    # Report match rates\n",
        "    both = (trips['orig_lat'].notna() & trips['dest_lat'].notna()).sum()\n",
        "    print(f\"    Both O/D coords matched: {both:,} / {len(trips):,}\")\n",
        "\n",
        "    # Keep only trips with valid coordinates\n",
        "    trips = trips.dropna(subset=['orig_lat', 'orig_lon', 'dest_lat', 'dest_lon'])\n",
        "    print(f\"    Trips with valid OD coords: {len(trips):,}\")\n",
        "\n",
        "    # -----------------------------------------------------------------\n",
        "    # Construct mode choice dependent variables\n",
        "    #\n",
        "    #\n",
        "    # -----------------------------------------------------------------\n",
        "    print(\"\\n  Constructing mode choice variables...\")\n",
        "\n",
        "    trips['mode'] = pd.to_numeric(trips['mode'], errors='coerce')\n",
        "\n",
        "    # Binary: Is this trip by transit? (公交出行 = 1)\n",
        "    trips['is_transit'] = trips['mode'].isin(Config.TRANSIT_MODES).astype(int)\n",
        "\n",
        "    # Binary: Is this trip by active mode? (步行/骑行 = 1)\n",
        "    trips['is_active'] = trips['mode'].isin(Config.ACTIVE_MODES).astype(int)\n",
        "\n",
        "    # Binary: Is this trip by walking? (步行 = 1)\n",
        "    trips['is_walk'] = (trips['mode'] == Config.WALKING_MODE).astype(int)\n",
        "\n",
        "    # Binary: Is this trip by auto/driving? (开车 = 1)\n",
        "    trips['is_auto'] = trips['mode'].isin(Config.AUTO_MODES).astype(int)\n",
        "\n",
        "    print(f\"    Transit trips: {trips['is_transit'].sum():,} ({trips['is_transit'].mean()*100:.1f}%)\")\n",
        "    print(f\"    Active trips:  {trips['is_active'].sum():,} ({trips['is_active'].mean()*100:.1f}%)\")\n",
        "    print(f\"    Walk trips:    {trips['is_walk'].sum():,} ({trips['is_walk'].mean()*100:.1f}%)\")\n",
        "    print(f\"    Auto trips:    {trips['is_auto'].sum():,} ({trips['is_auto'].mean()*100:.1f}%)\")\n",
        "\n",
        "    # Keep relevant columns\n",
        "    keep_cols = [\n",
        "        'sampno', 'perno', 'trip_seq', 'mode', 'travtime', 'distance',\n",
        "        'orig_locno', 'dest_locno',\n",
        "        'orig_lat', 'orig_lon', 'dest_lat', 'dest_lon',\n",
