        "        keep_cols.append('tpurp')\n",
        "\n",
        "    keep_cols = [c for c in keep_cols if c in trips.columns]\n",
        "    trips = trips[keep_cols].copy()\n",
        "\n",
        "    print(f\"\\n  Phase 3 complete: {len(trips):,} trip records\")\n",
        "    return trips\n",
        "\n"
