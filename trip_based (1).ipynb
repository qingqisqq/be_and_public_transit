    {
      "cell_type": "code",
      "source": [
        "\n",
        "# ############################################################################\n",
        "#\n",
        "#   PHASE 4: ASSIGN O/D TO CENSUS BLOCK GROUPS\n",
        "#\n",
        "#\n",
        "# ############################################################################\n",
        "\n",
        "def assign_od_to_zones(trips_df, cbg_shp_path):\n",
        "    \"\"\"\n",
        "    Assign each trip's origin and destination to a Census Block Group.\n",
        "\n",
        "    This is needed to look up zone-level built environment features\n",
        "    for both the origin and destination of each trip.\n",
        "\n",
        "    Unlike the gravity model, we don't aggregate trips into an OD matrix.\n",
        "    We keep each trip as a separate record.\n",
        "    \"\"\"\n",
        "\n",
        "    print(\"  Assigning O/D to Census Block Groups...\")\n",
        "\n",
        "    cbg = gpd.read_file(cbg_shp_path)\n",
        "    if cbg.crs is None:\n",
        "        cbg = cbg.set_crs(Config.CRS_WGS84)\n",
        "    cbg = cbg.to_crs(Config.CRS_ILLINOIS)\n",
        "\n",
        "    geoid_col = next(c for c in ['GEOID', 'GEOID20', 'GEOID10'] if c in cbg.columns)\n",
        "    cbg_join = cbg[[geoid_col, 'geometry']].copy()\n",
        "\n",
        "    # Assign ORIGIN to CBG\n",
        "    print(\"    Assigning origins...\")\n",
        "    orig_gdf = gpd.GeoDataFrame(\n",
        "        trips_df,\n",
        "        geometry=[Point(lon, lat) for lon, lat in\n",
        "                  zip(trips_df['orig_lon'], trips_df['orig_lat'])],\n",
        "        crs=Config.CRS_WGS84\n",
        "    ).to_crs(Config.CRS_ILLINOIS)\n",
        "\n",
        "    orig_joined = gpd.sjoin(orig_gdf, cbg_join, how='left', predicate='within')\n",
        "    trips_df = trips_df.copy()\n",
        "    trips_df['orig_GEOID'] = orig_joined[geoid_col].values\n",
        "\n",
        "    # Assign DESTINATION to CBG\n",
        "    print(\"    Assigning destinations...\")\n",
        "    dest_gdf = gpd.GeoDataFrame(\n",
        "        trips_df,\n",
        "        geometry=[Point(lon, lat) for lon, lat in\n",
        "                  zip(trips_df['dest_lon'], trips_df['dest_lat'])],\n",
        "        crs=Config.CRS_WGS84\n",
        "    ).to_crs(Config.CRS_ILLINOIS)\n",
        "\n",
        "    dest_joined = gpd.sjoin(dest_gdf, cbg_join, how='left', predicate='within')\n",
        "    trips_df['dest_GEOID'] = dest_joined[geoid_col].values\n",
        "\n",
        "    # Report\n",
        "    both = (trips_df['orig_GEOID'].notna() & trips_df['dest_GEOID'].notna()).sum()\n",
        "    print(f\"    Both O/D assigned: {both:,} / {len(trips_df):,}\")\n",
        "\n",
        "    trips_df = trips_df.dropna(subset=['orig_GEOID', 'dest_GEOID'])\n",
        "    print(f\"    Trips with valid zones: {len(trips_df):,}\")\n",
        "\n",
        "    return trips_df\n",
        "\n",
        "\n",
        "# ############################################################################\n",
        "#\n",
        "#   PHASE 5: ATTACH ZONE-LEVEL BE FEATURES TO ORIGIN AND DESTINATION\n",
        "#   \n",
        "#\n",
        "#  
        "#\n",
        "# ############################################################################\n",
        "\n",
        "def compute_zone_features(cbg_shp_path, epa_csv_path, be_csv_path,\n",
        "                           cbd_shp_path, park_shp_path, relevant_geoids):\n",
        "    \"\"\"\n",
        "    Compute features for each zone (CBG).\n",
        "\n",
        "    Same features will be used for BOTH origin and destination,\n",
        "    with different prefixes (O_ for origin, D_ for destination).\n",
        "    \"\"\"\n",
        "\n",
        "    print(\"  Computing zone-level features...\")\n",
        "\n",
        "    # --- Load CBG geometries ---\n",
        "    cbg = gpd.read_file(cbg_shp_path)\n",
        "    if cbg.crs is None:\n",
        "        cbg = cbg.set_crs(Config.CRS_WGS84)\n",
        "    cbg = cbg.to_crs(Config.CRS_ILLINOIS)\n",
        "\n",
        "    geoid_col = next(c for c in ['GEOID', 'GEOID20', 'GEOID10'] if c in cbg.columns)\n",
        "    cbg = cbg.rename(columns={geoid_col: 'GEOID'})\n",
        "    cbg = cbg[cbg['GEOID'].isin(relevant_geoids)].copy()\n",
        "\n",
        "    cbg['centroid_x'] = cbg.geometry.centroid.x\n",
        "    cbg['centroid_y'] = cbg.geometry.centroid.y\n",
        "\n",
        "    zone_df = cbg[['GEOID', 'centroid_x', 'centroid_y']].copy()\n",
        "    print(f\"    Relevant zones: {len(zone_df):,}\")\n",
        "\n",
        "    # --- EPA features (population density, employment density, entropy) ---\n",
        "    print(\"    Merging EPA features...\")\n",
        "    if os.path.exists(epa_csv_path):\n",
        "        epa = pd.read_csv(epa_csv_path, low_memory=False)\n",
        "        epa_gid = next((c for c in ['GEOID', 'GEOID20', 'GEOID10'] if c in epa.columns), None)\n",
        "        if epa_gid:\n",
        "            epa['GEOID'] = epa[epa_gid].astype(str).str.replace('.0', '', regex=False).str.zfill(12)\n",
        "            zone_df['GEOID'] = zone_df['GEOID'].astype(str).str.zfill(12)\n",
        "            epa_cols = ['GEOID'] + [c for c in Config.EPA_COLUMNS if c in epa.columns]\n",
        "            epa_sub = epa[epa_cols].drop_duplicates(subset='GEOID', keep='first')\n",
        "            zone_df = zone_df.merge(epa_sub, on='GEOID', how='left')\n",
        "            for c in Config.EPA_COLUMNS:\n",
        "                if c in zone_df.columns:\n",
        "                    print(f\"      {c}: {zone_df[c].notna().sum():,} matched\")\n",
        "\n",
        "    # --- BE metrics (grid → average per zone) ---\n",
        "    print(\"    Computing BE metrics per zone...\")\n",
        "    if os.path.exists(be_csv_path):\n",
        "        be = pd.read_csv(be_csv_path)\n",
        "        be['lat'] = pd.to_numeric(be['lat'], errors='coerce')\n",
        "        be['lon'] = pd.to_numeric(be['lon'], errors='coerce')\n",
        "        be = be.dropna(subset=['lat', 'lon'])\n",
        "        avail_be = [c for c in Config.BE_FEATURE_COLS if c in be.columns]\n",
        "\n",
        "        if avail_be:\n",
        "            be_gdf = gpd.GeoDataFrame(\n",
        "                be, geometry=[Point(ln, lt) for ln, lt in zip(be['lon'], be['lat'])],\n",
        "                crs=Config.CRS_WGS84\n",
        "            ).to_crs(Config.CRS_ILLINOIS)\n",
        "\n",
        "            cbg_for_join = cbg[['GEOID', 'geometry']].copy()\n",
        "            cbg_for_join['GEOID'] = cbg_for_join['GEOID'].astype(str).str.zfill(12)\n",
        "            be_in_cbg = gpd.sjoin(be_gdf, cbg_for_join, how='inner', predicate='within')\n",
        "            zone_be = be_in_cbg.groupby('GEOID')[avail_be].mean().reset_index()\n",
        "            zone_be.columns = ['GEOID'] + [f'avg_{c}' for c in avail_be]\n",
        "            zone_df = zone_df.merge(zone_be, on='GEOID', how='left')\n",
        "            print(f\"      BE averaged for {len(zone_be):,} zones\")\n",
        "\n",
        "    # --- Distance to CBD ---\n",
        "    print(\"    Computing distance to CBD...\")\n",
        "    if os.path.exists(cbd_shp_path):\n",
        "        cbd_gdf = gpd.read_file(cbd_shp_path)\n",
        "        if cbd_gdf.crs is None:\n",
        "            cbd_gdf = cbd_gdf.set_crs(Config.CRS_WGS84)\n",
        "        cbd_gdf = cbd_gdf.to_crs(Config.CRS_ILLINOIS)\n",
        "        cbd_boundary = cbd_gdf.geometry.unary_union\n",
        "\n",
        "        centroids = [Point(x, y) for x, y in\n",
        "                     zip(zone_df['centroid_x'], zone_df['centroid_y'])]\n",
        "        zone_df['dist_cbd_mi'] = [\n",
        "            0 if cbd_boundary.contains(pt) else pt.distance(cbd_boundary.boundary) / Config.FEET_PER_MILE\n",
        "            for pt in centroids\n",
        "        ]\n",
        "\n",
        "    # --- Distance to nearest park ---\n",
        "    print(\"    Computing distance to nearest park...\")\n",
        "    if os.path.exists(Config.PARK_SHP):\n",
        "        parks = gpd.read_file(Config.PARK_SHP)\n",
        "        if parks.crs is None:\n",
        "            parks = parks.set_crs(Config.CRS_WGS84)\n",
        "        parks = parks.to_crs(Config.CRS_ILLINOIS)\n",
        "        park_coords = np.column_stack([parks.geometry.x, parks.geometry.y])\n",
        "        park_tree = KDTree(park_coords)\n",
        "        cent_coords = np.column_stack([zone_df['centroid_x'], zone_df['centroid_y']])\n",
        "        dists, _ = park_tree.query(cent_coords)\n",
        "        zone_df['dist_park_mi'] = dists / Config.FEET_PER_MILE\n",
        "\n",
        "    # --- Transit accessibility (average per zone from household data) ---\n",
        "    print(\"    Computing transit accessibility per zone...\")\n",
        "    # We'll attach transit features at the trip level later using\n",
        "    # the household transit file, but also compute zone-level averages\n",
        "    # for destinations (which don't have household-level transit data)\n",
        "\n",
        "    print(f\"\\n  Zone features complete: {len(zone_df):,} zones, {len(zone_df.columns)} columns\")\n",
        "    return zone_df\n",
        "\n",
        "\n",
        "def attach_zone_features_to_trips(trips_df, zone_features):\n",
        "    \"\"\"\n",
        "    Attach zone-level features to both origin and destination of each trip.\n",
        "\n",
        "    Origin features get prefix O_ (e.g., O_D1B, O_avg_intersection_density)\n",
        "    Destination features get prefix D_ (e.g., D_D1B, D_avg_intersection_density)\n",
        "\n",
        "    给每次出行的起点加 O_ 前缀的特征，终点加 D_ 前缀的特征\n",
        "    \"\"\"\n",
        "\n",
        "    print(\"  Attaching zone features to trips...\")\n",
        "\n",
        "    meta_cols = ['GEOID', 'centroid_x', 'centroid_y']\n",
        "    feat_cols = [c for c in zone_features.columns if c not in meta_cols]\n",
        "\n",
        "    # --- Origin features (O_ prefix) ---\n",
        "    orig = zone_features.copy()\n",
        "    orig = orig.rename(columns={c: f'O_{c}' for c in feat_cols})\n",
        "    orig = orig.rename(columns={'GEOID': 'orig_GEOID'})\n",
        "    orig = orig.drop(columns=['centroid_x', 'centroid_y'], errors='ignore')\n",
        "\n",
        "    trips_df = trips_df.merge(orig, on='orig_GEOID', how='left')\n",
        "\n",
        "    # --- Destination features (D_ prefix) ---\n",
        "    dest = zone_features.copy()\n",
        "    dest = dest.rename(columns={c: f'D_{c}' for c in feat_cols})\n",
        "    dest = dest.rename(columns={'GEOID': 'dest_GEOID'})\n",
        "    dest = dest.drop(columns=['centroid_x', 'centroid_y'], errors='ignore')\n",
        "\n",
        "    trips_df = trips_df.merge(dest, on='dest_GEOID', how='left')\n",
        "\n",
        "    # --- Compute OD distance from centroids ---\n",
        "    print(\"    Computing O-D distance...\")\n",
        "    zf = zone_features.set_index('GEOID')\n",
        "\n",
        "    # Look up origin centroids\n",
        "    trips_df['o_cx'] = trips_df['orig_GEOID'].map(zf['centroid_x'])\n",
        "    trips_df['o_cy'] = trips_df['orig_GEOID'].map(zf['centroid_y'])\n",
        "    trips_df['d_cx'] = trips_df['dest_GEOID'].map(zf['centroid_x'])\n",
        "    trips_df['d_cy'] = trips_df['dest_GEOID'].map(zf['centroid_y'])\n",
        "\n",
        "    trips_df['od_dist_ft'] = np.sqrt(\n",
        "        (trips_df['o_cx'] - trips_df['d_cx'])**2 +\n",
        "        (trips_df['o_cy'] - trips_df['d_cy'])**2\n",
        "    )\n",
        "    trips_df['od_dist_mi'] = trips_df['od_dist_ft'] / Config.FEET_PER_MILE\n",
        "\n",
        "    # Clean up temporary columns\n",
        "    trips_df = trips_df.drop(columns=['o_cx', 'o_cy', 'd_cx', 'd_cy'], errors='ignore')\n",
        "\n",
        "    print(f\"    Mean OD distance: {trips_df['od_dist_mi'].mean():.2f} mi\")\n",
        "    print(f\"  Trips with O/D features: {len(trips_df):,}\")\n",
        "\n",
        "    return trips_df\n",
        "\n",
        "\n",
        "# ############################################################################\n",
        "#\n",
        "#   PHASE 6: ATTACH PERSON/HOUSEHOLD FEATURES\n",
        "#   
        "#\n",
        "# ############################################################################\n",
        "\n",
        "def attach_person_household_features(trips_df, person_df, household_df,\n",
        "                                      valid_sampnos=None):\n",
        "    \"\"\"\n",
        "    Attach person-level and household-level features to each trip.\n",
        "\n",
        "    These are the same sociodemographic features as in the person-level\n",
        "    pipeline, but now attached to each TRIP instead of each PERSON.\n",
        "    \"\"\"\n",
        "\n",
        "    print(\"  Attaching person/household features...\")\n",
        "\n",
        "    # ---- Person features ----\n",
        "    pdf = person_df.copy()\n",
        "    if valid_sampnos is not None:\n",
        "        pdf = pdf[pdf['sampno'].isin(valid_sampnos)]\n",
        "\n",
        "    pf = pd.DataFrame()\n",
        "    pf['sampno'] = pdf['sampno']\n",
        "    pf['perno']  = pdf['perno']\n",
        "\n",
        "    if 'age' in pdf.columns:\n",
        "        pf['age'] = pd.to_numeric(pdf['age'], errors='coerce')\n",
        "    if 'sex' in pdf.columns:\n",
        "        pf['Female'] = (pdf['sex'] == Config.SEX_FEMALE).astype(int)\n",
        "    if 'lic' in pdf.columns:\n",
        "        pf['License'] = (pdf['lic'] == 1).astype(int)\n",
        "    if 'emply_ask' in pdf.columns:\n",
        "        pf['Employed'] = (pdf['emply_ask'] == 1).astype(int)\n",
        "\n",
        "    # Student\n",
        "    s1 = pdf['wkstat'].isin(Config.WKSTAT_STUDENT) if 'wkstat' in pdf.columns else pd.Series(False, index=pdf.index)\n",
        "    s2 = pdf['stude'].isin([1, 2]) if 'stude' in pdf.columns else pd.Series(False, index=pdf.index)\n",
        "    pf['Student'] = (s1 | s2).astype(int)\n",
        "\n",
        "    if 'race' in pdf.columns:\n",
        "        pf['White'] = (pdf['race'] == Config.RACE_WHITE).astype(int)\n",
        "        pf['Black'] = (pdf['race'] == Config.RACE_BLACK).astype(int)\n",
        "        pf['Asian'] = (pdf['race'] == Config.RACE_ASIAN).astype(int)\n",
        "    if 'hisp' in pdf.columns:\n",
        "        pf['Hispanic'] = (pdf['hisp'] == 1).astype(int)\n",
        "    if 'educ' in pdf.columns:\n",
        "        pf['Bachelor_Above'] = (pdf['educ'] >= 5).astype(int)\n",
        "\n",
        "    # ---- Household features ----\n",
        "    hdf = household_df.copy()\n",
        "    if valid_sampnos is not None:\n",
        "        hdf = hdf[hdf['sampno'].isin(valid_sampnos)]\n",
        "\n",
        "    hf = pd.DataFrame()\n",
        "    hf['sampno'] = hdf['sampno']\n",
        "\n",
        "    if 'hhveh' in hdf.columns:\n",
        "        hf['hhveh'] = pd.to_numeric(hdf['hhveh'], errors='coerce').fillna(0)\n",
        "        hf['Zero_Vehicle_HH'] = (hf['hhveh'] == 0).astype(int)\n",
        "    if 'hhsize' in hdf.columns:\n",
        "        hf['hhsize'] = pd.to_numeric(hdf['hhsize'], errors='coerce').fillna(1)\n",
        "    if 'hhinc' in hdf.columns:\n",
        "        hf['hhinc'] = pd.to_numeric(hdf['hhinc'], errors='coerce')\n",
        "        hf['Low_Income']  = (hf['hhinc'] == 1).astype(int)\n",
        "        hf['High_Income'] = (hf['hhinc'] >= 4).astype(int)\n",
        "    if 'homeown' in hdf.columns:\n",
        "        hf['Home_Owner'] = hdf['homeown'].isin(Config.HOMEOWN_OWN).astype(int)\n",
        "\n",
        "    # ---- Merge to trips ----\n",
        "    trips_df = trips_df.merge(pf, on=['sampno', 'perno'], how='left')\n",
        "    trips_df = trips_df.merge(hf, on='sampno', how='left')\n",
        "\n",
        "    print(f\"  Trips with all features: {len(trips_df):,}\")\n",
        "    return trips_df\n",
        "\n"
      ],
