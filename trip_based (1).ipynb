    {
      "cell_type": "code",
      "source": [
        "\n",
        "# ############################################################################\n",
        "#\n",
        "#   PHASE 9: FIT LOGISTIC REGRESSION\n",
        "#\n",
        "#\n",
        "# ############################################################################\n",
        "\n",
        "def fit_logistic_models(trips_df):\n",
        "    \"\"\"\n",
        "    Fit logistic regression models for mode choice.\n",
        "\n",
        "    Dependent variable: is_transit (binary: 1=transit, 0=not transit)\n",
        "\n",
        "    Model comparison:\n",
        "      Model 1: Person/HH features only (baseline)\n",
        "      Model 2: + Origin BE features\n",
        "      Model 3: + Destination BE features\n",
        "      Model 4: + Both Origin AND Destination BE features (full model)\n",
        "    \"\"\"\n",
        "\n",
        "    import statsmodels.api as sm\n",
        "    from sklearn.model_selection import train_test_split\n",
        "    from sklearn.metrics import (accuracy_score, roc_auc_score,\n",
        "                                  classification_report, confusion_matrix)\n",
        "\n",
        "    print(\"\\n  Fitting Logistic Regression Models...\")\n",
        "    print(\"  Dependent Variable: is_transit (1=transit, 0=not transit)\")\n",
        "\n",
        "    df = trips_df.copy()\n",
        "\n",
        "    # -----------------------------------------------------------------\n",
        "    # Define feature groups\n",
        "    # -----------------------------------------------------------------\n",
        "\n",
        "    # Person/household features\n",
        "    person_hh_feats = [\n",
        "        'age', 'Female', 'License', 'Employed', 'Student',\n",
        "        'White', 'Black', 'Asian', 'Hispanic', 'Bachelor_Above',\n",
        "        'hhveh', 'Zero_Vehicle_HH', 'hhsize', 'Low_Income', 'High_Income',\n",
        "        'Home_Owner'\n",
        "    ]\n",
        "    person_hh_feats = [c for c in person_hh_feats if c in df.columns]\n",
        "\n",
        "    # Trip-level features\n",
        "    trip_feats = ['od_dist_mi']\n",
        "    trip_feats = [c for c in trip_feats if c in df.columns]\n",
        "\n",
        "    # Origin BE features (O_ prefix)\n",
        "    orig_be_feats = [c for c in df.columns if c.startswith('O_')]\n",
        "    orig_be_feats = [c for c in orig_be_feats if df[c].notna().mean() > 0.5]\n",
        "\n",
        "    # Destination BE features (D_ prefix)\n",
        "    dest_be_feats = [c for c in df.columns if c.startswith('D_')]\n",
        "    dest_be_feats = [c for c in dest_be_feats if df[c].notna().mean() > 0.5]\n",
        "\n",
        "    print(f\"\\n    Person/HH features: {len(person_hh_feats)}\")\n",
        "    print(f\"    Trip features:      {len(trip_feats)}\")\n",
        "    print(f\"    Origin BE features: {len(orig_be_feats)}\")\n",
        "    print(f\"    Dest BE features:   {len(dest_be_feats)}\")\n",
        "\n",
        "    # -----------------------------------------------------------------\n",
        "    # Prepare data\n",
        "    # -----------------------------------------------------------------\n",
        "    all_feats = person_hh_feats + trip_feats + orig_be_feats + dest_be_feats\n",
        "    df_clean = df.dropna(subset=all_feats + ['is_transit'])\n",
        "\n",
        "    # Replace negative values with NaN and drop\n",
        "    for col in all_feats:\n",
        "        if col in df_clean.columns:\n",
        "            df_clean.loc[df_clean[col] < 0, col] = np.nan\n",
        "    df_clean = df_clean.dropna(subset=all_feats)\n",
        "\n",
        "    print(f\"    Clean observations: {len(df_clean):,}\")\n",
        "    print(f\"    Transit rate: {df_clean['is_transit'].mean()*100:.1f}%\")\n",
        "\n",
        "    # Train/test split\n",
        "    train, test = train_test_split(df_clean, test_size=0.2, random_state=42)\n",
        "    print(f\"    Train: {len(train):,} | Test: {len(test):,}\")\n",
        "\n",
        "    y_train = train['is_transit']\n",
        "    y_test  = test['is_transit']\n",
        "\n",
        "    # -----------------------------------------------------------------\n",
        "    # Define 4 models with increasing feature sets\n",
        "    # -----------------------------------------------------------------\n",
        "    models = {\n",
        "        'Model 1: Person/HH only':\n",
        "            person_hh_feats + trip_feats,\n",
        "        'Model 2: + Origin BE':\n",
        "            person_hh_feats + trip_feats + orig_be_feats,\n",
        "        'Model 3: + Destination BE':\n",
        "            person_hh_feats + trip_feats + dest_be_feats,\n",
        "        'Model 4: + Both O & D BE (Full)':\n",
        "            person_hh_feats + trip_feats + orig_be_feats + dest_be_feats,\n",
        "    }\n",
        "\n",
        "    results = {}\n",
        "\n",
        "    for name, feats in models.items():\n",
        "        print(f\"\\n    {'='*60}\")\n",
        "        print(f\"    {name}\")\n",
        "        print(f\"    {'='*60}\")\n",
        "        print(f\"    Features: {len(feats)}\")\n",
        "\n",
        "        feats_avail = [f for f in feats if f in df_clean.columns]\n",
        "\n",
        "        X_train = sm.add_constant(train[feats_avail].astype(float))\n",
        "        X_test  = sm.add_constant(test[feats_avail].astype(float))\n",
        "\n",
        "        try:\n",
        "            logit = sm.Logit(y_train, X_train).fit(disp=0)\n",
        "\n",
        "            # Predict probabilities\n",
        "            y_prob = logit.predict(X_test)\n",
        "            y_pred = (y_prob >= 0.5).astype(int)\n",
        "\n",
        "            # Evaluate\n",
        "            acc = accuracy_score(y_test, y_pred)\n",
        "            try:\n",
        "                auc = roc_auc_score(y_test, y_prob)\n",
        "            except:\n",
        "                auc = np.nan\n",
        "\n",
        "            print(f\"    Accuracy:     {acc:.4f}\")\n",
        "            print(f\"    AUC-ROC:      {auc:.4f}\")\n",
        "            print(f\"    Pseudo R²:    {logit.prsquared:.4f}\")\n",
        "            print(f\"    Log-Lik:      {logit.llf:.1f}\")\n",
        "            print(f\"    AIC:          {logit.aic:.1f}\")\n",
        "            print(f\"    BIC:          {logit.bic:.1f}\")\n",
        "\n",
        "            results[name] = {\n",
        "                'model': logit,\n",
        "                'accuracy': acc,\n",
        "                'auc': auc,\n",
        "                'pseudo_r2': logit.prsquared,\n",
        "                'aic': logit.aic,\n",
        "                'n_features': len(feats_avail)\n",
        "            }\n",
        "\n",
        "            # Print significant coefficients for full model\n",
        "            if 'Full' in name:\n",
        "                print(f\"\\n    Significant coefficients (p < 0.05):\")\n",
        "                pvals = logit.pvalues\n",
        "                coefs = logit.params\n",
        "                sig = pvals[pvals < 0.05].index\n",
        "                for var in sig:\n",
        "                    print(f\"      {var:<35} coef={coefs[var]:>8.4f}  p={pvals[var]:.4f}\")\n",
        "\n",
        "        except Exception as e:\n",
        "            print(f\"    FAILED: {e}\")\n",
        "\n",
        "    # -----------------------------------------------------------------\n",
        "    # Summary comparison table\n",
        "    # -----------------------------------------------------------------\n",
        "    print(f\"\\n\\n    {'='*70}\")\n",
        "    print(f\"    MODEL COMPARISON SUMMARY\")\n",
        "    print(f\"    {'='*70}\")\n",
        "    print(f\"    {'Model':<40} {'Accuracy':>10} {'AUC':>8} {'Pseudo R²':>10} {'AIC':>10}\")\n",
        "    print(f\"    {'-'*70}\")\n",
        "    for name, r in results.items():\n",
        "        print(f\"    {name:<40} {r['accuracy']:>10.4f} {r['auc']:>8.4f} \"\n",
        "              f\"{r['pseudo_r2']:>10.4f} {r['aic']:>10.1f}\")\n",
        "\n",
        "    return results\n",
        "\n"
      ],
